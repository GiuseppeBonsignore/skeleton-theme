{{ 'base-bonsignore.css' | asset_url | stylesheet_tag }}

<header class="bg-primary px-4 py-3 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    
    <!-- Logo & Ritiro Badge -->
    <div class="flex items-center justify-between w-full md:w-auto gap-4">
      <a href="/" class="text-white font-bold text-2xl no-underline">
        BONSIGNORE
      </a>
      <span class="badge bg-accent hidden md:inline-block">🚜 Ritiro in Sede Disponibile</span>
    </div>

    <!-- Full-Width Search Bar (Ricerca Codici OEM) -->
    <div class="w-full md:flex-1 max-w-3xl">
      <form action="/search" method="get" class="relative flex w-full">
        <input type="hidden" name="type" value="product">
        <input 
          type="search" 
          name="q" 
          placeholder="Cerca codice OEM, modello o ricambio (es. Filtro Aria Lombardini)..."
          class="w-full p-3 rounded-lg border-2 border-transparent focus:border-accent text-iron text-lg"
          required
        >
        <button type="submit" class="absolute right-2 top-2 bg-primary text-white px-4 py-1 rounded-md font-bold">
          Cerca
        </button>
      </form>
    </div>

    <!-- Mobile Icon Menu -->
    <nav class="flex w-full md:w-auto justify-between md:justify-end gap-6 text-white text-sm font-bold">
      <a href="/collections/ricambi" class="flex flex-col items-center no-underline"><span class="text-xl">⚙️</span>Ricambi</a>
      <a href="/collections/macchine" class="flex flex-col items-center no-underline"><span class="text-xl">🚜</span>Macchine</a>
      <a href="/pages/assistenza" class="flex flex-col items-center no-underline"><span class="text-xl">👨‍🔧</span>Assistenza</a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Bonsignore Header",
  "settings":[]
}
{% endschema %}
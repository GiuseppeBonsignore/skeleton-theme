<section class="max-w-7xl mx-auto px-4 py-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 h-auto md:h-96">
    
    <!-- Percorso Locale (Ritiro) -->
    <a href="/collections/all" class="bg-primary rounded-xl p-8 flex flex-col justify-center items-center text-center no-underline hover:opacity-95 transition shadow-lg">
      <span class="text-6xl mb-4">🏬</span>
      <h2 class="text-3xl font-extrabold text-white mb-2">Sei di zona?</h2>
      <p class="text-white text-lg">Prenota online, ritira al volo in magazzino.</p>
      <span class="mt-6 bg-white text-primary px-6 py-3 rounded-full font-bold inline-block">Acquista e Ritira in Negozio</span>
    </a>

    <!-- Percorso Nazionale (Spedizione) -->
    <a href="/collections/all" class="bg-accent rounded-xl p-8 flex flex-col justify-center items-center text-center no-underline hover:opacity-95 transition shadow-lg">
      <span class="text-6xl mb-4">🚚</span>
      <h2 class="text-3xl font-extrabold text-white mb-2">Spedizione Veloce</h2>
      <p class="text-white text-lg">In tutta Italia, sicura e tracciata con Bartolini.</p>
      <span class="mt-6 bg-white text-accent px-6 py-3 rounded-full font-bold inline-block">Scopri il Catalogo Nazionale</span>
    </a>

  </div>
</section>

{% schema %}
{
  "name": "Bonsignore Split Hero",
  "presets": [{ "name": "Split Hero Percorsi" }]
